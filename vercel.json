{
    "version": 2,
    "outputDirectory": "public",
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|fonts|build|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": ":memory:"
    }
}