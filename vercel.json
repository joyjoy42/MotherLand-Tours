{
    "version": 2,
    "builds": [
        {
            "src": "api/*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/phpinfo",
            "dest": "/api/phpinfo.php"
        },
        {
            "src": "/api/artisan",
            "dest": "/api/artisan.php"
        },
        {
            "src": "/api/ls",
            "dest": "/api/ls.php"
        },
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts|assets|favicon.ico|robots.txt)",
            "dest": "/public/$1"
        },
        {
            "src": "/(css|js|images|fonts|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "APP_URL": "https://mother-land-tours.vercel.app",
        "ASSET_URL": "https://mother-land-tours.vercel.app",
        "VIEW_COMPILED_PATH": "/tmp",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": ":memory:"
    }
}